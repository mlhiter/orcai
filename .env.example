# Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/orcai?schema=public"

# OpenAI (optional - if omitted, app falls back to template generation)
OPENAI_API_KEY=""
OPENAI_MODEL="gpt-4.1-mini"
# OpenAI-compatible base URL, keep /v1 (or provide full /responses endpoint)
OPENAI_BASE_URL="https://api.openai.com/v1"

# Optional Tavily search key (if omitted, app uses DuckDuckGo instant API)
TAVILY_API_KEY=""

# Generation behavior
MIN_MODULES="5"
SEARCH_RESULT_LIMIT="6"
